#include <LiquidCrystal.h>

const int rs = 12, en = 11, d4 = 5, d5 = 4, d6 = 3, d7 = 2;
LiquidCrystal lcd(rs, en, d4, d5, d6, d7);

void setup(){
 lcd.begin(16, 2);
 lcd.print("HELLO WORLD! hello world! HELLO WORLD!");
}
void loop(){
  for (int i = 0; i < 16; i++){
  lcd.scrollDisplayLeft();
  delay(300);  
  }
  for (int i = 0; i < 16; i++){
  lcd.scrollDisplayRight();
  delay(300); 
}
}
